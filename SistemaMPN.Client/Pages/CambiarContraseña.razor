@page "/RestaurarContrasenia"
@using SistemaMPN.Shared.DTO

@layout SistemaMPN.Client.Layout.LoginLayout
@inject HttpClient httpClient
@inject NavigationManager Navigation
@inject ISnackbar Snackbar

<PageTitle>Restaurar Contraseña</PageTitle>

<MudPaper Elevation="2" Class="pa-8" Style="max-width: 500px; margin: 0 auto;">
    @if (!correoEnviado)
    {
        <MudText Typo="Typo.h4" Class="mb-6 text-center">
            <MudIcon Icon="@Icons.Material.Filled.Password" Size="Size.Large" Class="mr-2"/>
            Restaurar Contraseña
        </MudText>

        <EditForm id="change_password_form_id" Model="forgotPasswordDTO" OnValidSubmit="CambiarContrasenia">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="forgotPasswordDTO.Correo"
                            Label="Correo"
                            Variant="Variant.Outlined"
                            FullWidth="true"
                            Required="true"
                            Class="mb-4"
                            Immediate="true"
                            For="@(() => forgotPasswordDTO.Correo)" />

            <MudLink Href="/"
                    Class="mb-4 d-block"
                    Typo="Typo.body2"
                    Color="Color.Primary">
                Volver
            </MudLink>

            <MudButton ButtonType="ButtonType.Submit"
                        Variant="Variant.Filled"
                        FullWidth="true"
                        Class="mt-4 botton-azul-oscuro"
                        Disabled="@isLoading">
                @if (isLoading)
                {
                    <MudProgressCircular Size="Size.Small" Color="Color.Inherit" />
                    <span class="ml-2">Verificando...</span>
                }
                else
                {
                    <span>Enviar</span>
                }
            </MudButton>

            @if (mostrarAyudaCorreo)
            {
                <MudAlert Severity="Severity.Info" Class="mt-4" Dense="true" Variant="Variant.Outlined">
                    Si no está seguro de cuál era el correo vinculado a su cuenta, envíe un correo al administrador: 
                    <MudLink Href="mailto:blancosonrriente@gmail.com" Color="Color.Primary">
                        blancosonrriente@gmail.com
                    </MudLink>
                </MudAlert>
            }
        </EditForm>
    }
    else
    {
        <MudText Typo="Typo.h4" Class="mb-6 text-center">
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Size="Size.Large" Class="mr-2"/>
            Correo Enviado
        </MudText>

        <MudText Typo="Typo.body1" Class="mb-6 text-center">
            Se ha enviado a su correo el método para cambiar su contraseña.
        </MudText>

        <MudLink Href="/"
                Class="mb-4 d-block"
                Typo="Typo.body2"
                Color="Color.Primary">
            Volver al inicio de sesión
        </MudLink>
    }
</MudPaper>


@code {
    ForgotPasswordDTO forgotPasswordDTO = new ForgotPasswordDTO();
    bool isLoading = false;
    bool correoEnviado = false;
    bool mostrarAyudaCorreo = false;
    async Task CambiarContrasenia()
    {
        try
        {
            mostrarAyudaCorreo = false;
            isLoading = true;
            StateHasChanged();
            var result = await httpClient.PostAsJsonAsync("api/login/ContraseniaOlvidada", forgotPasswordDTO);
            
            if (result.IsSuccessStatusCode)
            {
                correoEnviado = true;
                Snackbar.Add("Se ha enviado un correo con las instrucciones para cambiar su contraseña", Severity.Success);
            }
            else
            {
                var errorContent = await result.Content.ReadAsStringAsync();
                Snackbar.Add($"Error: {errorContent}", Severity.Error);
                mostrarAyudaCorreo = true;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}












@using MudBlazor
@using SistemaMPN.Shared.DTO

@inject ISnackbar Snackbar

<EditForm Model="nota" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Notes" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Agregar Nota</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="border: 1px solid var(--mud-palette-divider);">
                    <MudText Typo="Typo.subtitle2" Class="mb-3" Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Filled.Edit" Size="Size.Small" Class="mr-1" />
                        Comentarios *
                    </MudText>
                    <MudTextField @bind-Value="nota.Comentarios"
                                  Label="Ingrese los comentarios de la reunión"
                                  Variant="Variant.Outlined"
                                  Lines="5"
                                  Required="true"
                                  For="@(() => nota.Comentarios)"
                                  RequiredError="Los comentarios son obligatorios" />
                </MudPaper>
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancelar"
                       Color="Color.Default"
                       Variant="Variant.Outlined">
                Cancelar
            </MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       ButtonType="ButtonType.Submit"
                       StartIcon="@Icons.Material.Filled.Check">
                Guardar
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public int ReunionId { get; set; }

    private NotaDTO nota = new();

    protected override void OnInitialized()
    {
        nota.IdReunion = ReunionId;
    }

    private void Guardar()
    {
        MudDialog.Close(DialogResult.Ok(nota));
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}

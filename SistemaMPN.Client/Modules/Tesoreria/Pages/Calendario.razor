@page "/tesoreria/calendario"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SistemaMPN.Client.Modules.Tesoreria.Dialogs
@using SistemaMPN.Client.Modules.Tesoreria.ViewModels
@using SistemaMPN.Client.Pages
@using SistemaMPN.Client.Pages.ViewModels
@using SistemaMPN.Shared.DTO
@using System.Security.Claims
@layout SistemaMPN.Client.Layout.TesoreriaLayout

@inject NavigationManager Nav
@inject IDialogService DialogService
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Calendario de tesoreros</PageTitle>

<AuthorizeView Roles="admin, tesorero, protesorero, auditor">
    <Authorized>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="py-6">
            <!-- Header Section -->
            <MudPaper Elevation="0" Class="pa-6 rounded-lg" Style="background: linear-gradient(135deg, var(--color-primario) 0%, rgba(30, 58, 138, 0.8) 100%);">
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="flex-wrap" Spacing="2">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth"
                                Size="Size.Large"
                                Style="color: var(--color-texto-claro);" />
                        <MudStack Spacing="0">
                            <MudText Typo="Typo.h4" Style="color: var(--color-texto-claro);">
                                Calendario de Turnos
                            </MudText>
                            <MudText Typo="Typo.body2" Style="color: var(--color-texto-claro);">
                                Gestión de turnos y propuestas de cambio
                            </MudText>
                        </MudStack>
                    </MudStack>
                    <MudStack Row="true" Spacing="2" Class="flex-wrap">
                        @if (!esTesorero && !esAuditor)
                        {
                            <MudButton StartIcon="@Icons.Material.Filled.Event"
                                       OnClick="AsignarTurnos"
                                       Variant="Variant.Filled"
                                       Color="Color.Success"
                                       Style="background-color: var(--color-exito);">
                                Asignar turnos
                            </MudButton>
                        }
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Inherit"
                                   StartIcon="@Icons.Material.Filled.Refresh"
                                   OnClick="CargarTurnosYPropuestas"
                                   Disabled="@cargando"
                                   Style="color: var(--color-texto-claro); border-color: var(--color-texto-claro);">
                            Actualizar
                        </MudButton>
                    </MudStack>
                </MudStack>
            </MudPaper>

            <!-- Calendar Section -->
            <MudCalendar T="TurnoViewModel"
                         Class="mt-6"
                            Context="turnosCal"
                            Height="600"
                            HighlightToday="true"
                            Square="false"
                            ShowTodayButton="true"
                            ShowDropdownViewSelector="true"
                            ShowPrevNextButtons="false"
                            Outlined="true"
                            ToolbarPadding="4"
                            Items="_turnos"
                            IsDateTimeDisabledFunc="IsDateTimeDisabled"
                            AdditionalDateTimeClassesFunc="AdditionalDateTimeClasses"
                            ViewChanged="OnViewChanged"
                            @ref="_calendarRef">
                <CellTemplate>
                    @if (_vistaActual == CalendarView.Month || _vistaActual == CalendarView.Week)
                    {
                        var textColor = GetTextColor(turnosCal.turnoDTO.Color);
                        <MudHidden Breakpoint="Breakpoint.SmAndDown">
                            <MudPaper Class="d-flex flex-column h-100 w-100 border border-2 overflow-hidden p-1"
                                        Style=@($"background-color: {turnosCal.turnoDTO.Color}")>
                                <MudText Typo="Typo.body1" Align="Align.Center" Style=@($"color: {textColor}")>Turno</MudText>
                            </MudPaper>
                        </MudHidden>

                        <MudHidden Breakpoint="Breakpoint.MdAndUp">
                            <div class="d-flex justify-content-center align-items-center h-100 w-100">
                                <MudIcon Icon="@Icons.Material.Filled.Circle"
                                            Style="@($"color: {turnosCal.turnoDTO.Color}")"
                                            Size="Size.Small" />
                            </div>
                        </MudHidden>
                    }
                    else
                    {
                        var textColorList = GetTextColor(turnosCal.turnoDTO.Color);
                        <MudPaper Class="d-flex flex-column h-100 w-100 border border-2 overflow-hidden p-1">
                            <MudText Typo="Typo.body1"
                                    Align="Align.Center"
                                    Style=@($"background-color: {turnosCal.turnoDTO.Color}; color: {textColorList}")>Turno</MudText>
                        </MudPaper>
                    }
                </CellTemplate>
            </MudCalendar>
                

            <!-- Tabs Section -->
            <MudStack Spacing="4" Class="mt-6">
                <MudTabs Color="Color.Primary" Elevation="2" Rounded="true" ApplyEffectsToContainer="true">
                    <!-- TAB: Turnos del tesorero -->
                    <MudTabPanel Text="Turnos" Icon="@Icons.Material.Filled.CalendarMonth">
                        <MudPaper Elevation="0" Class="pa-4" Style="background-color: var(--mud-palette-grey-light);">
                            @RenderTurnos()
                        </MudPaper>
                    </MudTabPanel>

                    <!-- TAB: Peticiones de cambio de turno -->
                    <MudTabPanel Text="Propuestas de cambio" Icon="@Icons.Material.Filled.Schedule">
                        <MudPaper Elevation="0" Class="pa-4" Style="background-color: var(--mud-palette-grey-light);">
                            @RenderPropuestas()
                        </MudPaper>
                    </MudTabPanel>
                </MudTabs>
            </MudStack>
        </MudContainer>
    </Authorized>
    <NotAuthorized>
        <MudContainer Class="py-8">
            <ReDirectToLogin />
        </MudContainer>
    </NotAuthorized>
</AuthorizeView>

@code {
    private List<TurnoViewModel> _turnos = new();
    private List<PropuestaDeCambioDTO> _propuestas = new();
    private List<TesoreroDisponibleDTO> _tesoreros = new();
    private CalendarView _vistaActual = CalendarView.Month;
    private bool cargando = false;
    private bool esTesorero = true;
    private bool esAuditor = false;
    private int idTesorero = 12;
    private TurnoDTO? turnoCargado = null;
    private MudCalendar<TurnoViewModel>? _calendarRef;

    private DialogOptions opcionesDialog = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true,
                                                               BackdropClick = false, CloseOnEscapeKey = false };

    private int? tesoreroSeleccionado = null;
    private string filtroEstado = "Todas";
    private List<PropuestaDeCambioDTO> _propuestasHistorial = new();
    private List<TurnoViewModel> _turnosFiltrados = new();

    private int paginaActual = 1;
    private int itemsPorPagina = 5;
    private int totalPaginasTurnos = 1;
    private int totalPaginasPropuestas = 1;
    private List<TurnoViewModel> turnosPaginados = new();
    private List<PropuestaDeCambioDTO> propuestasPaginadas = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AsignarRol();
            await CargarTesoreros();
            await CargarTurnosYPropuestas();
            StateHasChanged();
        }
    }

    private async Task AsignarRol()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        esTesorero = authState.User.IsInRole("tesorero") &&
                 !authState.User.IsInRole("admin") &&
                 !authState.User.IsInRole("protesorero");

        esAuditor = authState.User.IsInRole("auditor");
    }

    private async Task CargarTesoreros()
    {
        try
        {
            var tesoreros = await Http.GetFromJsonAsync<List<TesoreroDisponibleDTO>>("api/turno/GetTesorerosDisponibles");
            var id = await Http.GetFromJsonAsync<int>("api/turno/GetIdTesoreroActual");

            if (tesoreros != null && tesoreros.Any())
            {
                _tesoreros = tesoreros;
                idTesorero = id;
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar tesoreros: {ex.Message}", Severity.Error);
        }
    }

    private async Task CargarTurnosYPropuestas()
    {
        try
        {
            cargando = true;
            var turnos = await Http.GetFromJsonAsync<List<TurnoDTO>>("api/turno/GetTurnos");
            var propuestas = await Http.GetFromJsonAsync<List<PropuestaDeCambioDTO>>("api/turno/GetPropuestas");

            if (turnos != null && turnos.Any())
            {
                _turnos.Clear();

                turnos.ForEach(t => _turnos.Add(new TurnoViewModel
                {
                    Start = t.Fecha.GetValueOrDefault(),
                    End = t.Fecha.GetValueOrDefault(),
                    turnoDTO = t
                }));
                _turnosFiltrados = _turnos.ToList();

                ActualizarPaginacion();
            }

            if (propuestas != null && propuestas.Any())
            {
                _propuestas = propuestas.Where(p => p.Estado.Equals("Pendiente")).ToList();
                _propuestasHistorial = propuestas;

                ActualizarPaginacionPropuestas();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            cargando = false;
        }
    }

    public async Task AsignarTurnos()
    {
        var parameters = new DialogParameters<DialogAsignarTurnos>();
        parameters.Add(x => x.tesoreros, _tesoreros);

        var result = await DialogService.ShowAsync<DialogAsignarTurnos>("Asignar Turnos", parameters, opcionesDialog);

        var dialogResult = await result.Result;
        if (!dialogResult.Canceled && dialogResult.Data is List<TurnoDTO> nuevosTurnos)
        {
            try
            {
                var response = await Http.PostAsJsonAsync<List<TurnoDTO>>("api/turno/AsignarTurnos", nuevosTurnos);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Turnos asignados correctamente", Severity.Success);
                    await CargarTurnosYPropuestas();
                }
                else
                {
                    Snackbar.Add("Error al asignar los turnos", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }


    private async Task ActualizarPropuesta(PropuestaDeCambioDTO propuesta, string nuevoEstado)
    {
        var parameters = new DialogParameters<DialogCambio>();
        IDialogReference result;

        if(nuevoEstado == "Aceptada") {
            parameters.Add(x => x.ContentText, $"¿Aceptar esta propuesta de cambio?");
            parameters.Add(x => x.ButtonText, "Aceptar");

            result = await DialogService.ShowAsync<DialogCambio>("Aprobar cambio", parameters);
        } else {
            parameters.Add(x => x.ContentText, $"¿Rechazar esta propuesta de cambio?");
            parameters.Add(x => x.ButtonText, "Rechazar");

            result = await DialogService.ShowAsync<DialogCambio>("Rechazar cambio", parameters);
        }

        var dialogResult = await result.Result;

        if (!dialogResult.Canceled)
        {
            try
            {
                var response = await Http.PutAsync($"api/turno/ActualizarPropuesta/{propuesta.IdPropuestaDeCambio}/{nuevoEstado}", null);

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Propuesta de cambio aceptada correctamente", Severity.Success);
                    await CargarTurnosYPropuestas();
                }
                else
                {
                    Snackbar.Add("Error al aceptar la propuesta de cambio", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            } finally
            {
                _propuestas.Remove(propuesta);
                StateHasChanged();
            }
        }
    }

    public async Task PedirCambio(int idTurno)
    {
        var parameters = new DialogParameters<DialogPropuesta>();
        parameters.Add(x => x.ButtonText, "Aceptar");
        parameters.Add(x => x.tesoreros, _tesoreros.Where(t => t.IdTesorero != idTesorero).ToList());
        parameters.Add(x => x.Turno, idTurno);

        var result = await DialogService.ShowAsync<DialogPropuesta>("Pedir el cambio", parameters);
        var dialogResult = await result.Result;

        if (!dialogResult.Canceled && dialogResult.Data is PropuestaDeCambioDTO propuesta)
        {
            try
            {
                var response = await Http.PostAsJsonAsync("api/turno/PedirCambio/", propuesta);
                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Propuesta de cambio enviada correctamente", Severity.Success);
                    await CargarTurnosYPropuestas();
                }
                else
                {
                    Snackbar.Add("Error al enviar la propuesta de cambio", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private bool IsDateTimeDisabled(DateTime dateTime, CalendarView view)
    {
        return dateTime < DateTime.Today || view != CalendarView.Month;
    }

    private string AdditionalDateTimeClasses(DateTime dateTime, CalendarView view)
    {
        if (dateTime < DateTime.Today || view != CalendarView.Month)
        {
            return "gray-background";
        }

        return string.Empty;
    }

    private void OnViewChanged(CalendarView nuevaVista) => _vistaActual = nuevaVista;

    private string GetTextColor(MudBlazor.Utilities.MudColor backgroundColor)
    {
        if (backgroundColor == null)
            return "white";

        // Extract RGB components from MudColor
        var r = backgroundColor.R;
        var g = backgroundColor.G;
        var b = backgroundColor.B;

        // Calculate luminance using WCAG formula
        var luminance = (0.299 * r + 0.587 * g + 0.114 * b) / 255;

        // Use white text for dark backgrounds, black for light backgrounds
        return luminance > 0.5 ? "black" : "white";
    }

    private void ActualizarPaginacionPropuestas()
    {
        totalPaginasPropuestas = (int)Math.Ceiling((decimal)_propuestasHistorial.Count / itemsPorPagina);
        if (totalPaginasPropuestas == 0) totalPaginasPropuestas = 1;
        paginaActual = 1;

        propuestasPaginadas = _propuestasHistorial
            .Take(itemsPorPagina)
            .ToList();
    }

    private void ActualizarPaginacion()
    {
        totalPaginasTurnos = (int)Math.Ceiling((decimal)_turnosFiltrados.Count / itemsPorPagina);
        if (totalPaginasTurnos == 0) totalPaginasTurnos = 1;
        paginaActual = 1;
        ActualizarTurnosPaginados();
    }

    private void ActualizarTurnosPaginados()
    {
        var skip = (paginaActual - 1) * itemsPorPagina;
        turnosPaginados = _turnosFiltrados.Skip(skip).Take(itemsPorPagina).ToList();
    }

    private void CambiarPagina(int pagina)
    {
        if (pagina >= 1 && pagina <= totalPaginasTurnos)
        {
            paginaActual = pagina;
            ActualizarTurnosPaginados();
        }
    }

    private void CambiarPaginaPropuestas(int pagina)
    {
        if (pagina >= 1 && pagina <= totalPaginasPropuestas)
        {
            paginaActual = pagina;
            FiltrarPropuestas();
        }
    }

    private async Task EditarTurno(TurnoDTO turno)
    {
        var parameters = new DialogParameters<DialogTurno>();
        parameters.Add(x => x.tesoreros, _tesoreros);
        parameters.Add(x => x.Turno, turno);

        var result = await DialogService.ShowAsync<DialogTurno>("Editar Turno", parameters, opcionesDialog);
        var dialogResult = await result.Result;

        if (!dialogResult.Canceled && dialogResult.Data is TurnoDTO turnoActualizado)
        {
            try
            {
                var response = await Http.PatchAsJsonAsync($"api/turno/ActualizarTurno/{turno.IdTurno}", turnoActualizado);

                if (response.IsSuccessStatusCode)
                {
                    Snackbar.Add("Turno actualizado correctamente", Severity.Success);
                    await CargarTurnosYPropuestas();
                }
                else
                {
                    Snackbar.Add("Error al actualizar el turno", Severity.Error);
                }
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            }
        }
    }

    private void FiltrarTurnosPorTesorero()
    {
        if (tesoreroSeleccionado == null)
        {
            _turnosFiltrados = _turnos.ToList();
        }
        else
        {
            _turnosFiltrados = _turnos.Where(t => t.turnoDTO.IdTesorero == tesoreroSeleccionado).ToList();
        }

        ActualizarPaginacion();
        StateHasChanged();
    }


    private void FiltrarPropuestas()
    {
        var propuestasFiltradas = filtroEstado == "Todas"
            ? _propuestasHistorial
            : _propuestasHistorial.Where(p => p.Estado == filtroEstado).ToList();

        totalPaginasPropuestas = (int)Math.Ceiling((decimal)propuestasFiltradas.Count / itemsPorPagina);
        if (totalPaginasPropuestas == 0) totalPaginasPropuestas = 1;

        var skip = (paginaActual - 1) * itemsPorPagina;
        propuestasPaginadas = propuestasFiltradas.Skip(skip).Take(itemsPorPagina).ToList();

        StateHasChanged();
    }

    private string ObtenerNombreTesorero(int idTesoreroBusqueda)
    {
        var tesorero = _tesoreros.FirstOrDefault(t => t.IdTesorero == idTesoreroBusqueda);
        return tesorero != null ? $"{tesorero.Nombre}" : "Desconocido";
    }

    private async Task CargarTurno(int idTurno)
    {
        if (idTurno == turnoCargado?.IdTurno) return;

        try
        {
            turnoCargado = await Http.GetFromJsonAsync<TurnoDTO>($"api/turno/GetTurno/{idTurno}");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al cargar el turno: {ex.Message}", Severity.Error);
        }
    }

    private RenderFragment RenderTurnos() => __builder =>
    {
        paginaActual = 1;

        if (cargando)
        {
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-6">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Cargando turnos...</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>;
            return;
        }

        if (_turnos.Count == 0 && !cargando)
        {
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-6">
                        <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.5;" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">No hay turnos pendientes</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            Los turnos aparecerán aquí una vez que sean asignados
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>;
            return;
        }

        if (esTesorero)
        {
            @RenderTurnosVistaTesorero();
        }
        else
        {
            @RenderTurnosVistaProTesorero();
        }

        <!-- Paginación -->
        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-4">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Mostrando @((paginaActual - 1) * itemsPorPagina + 1) a
                @Math.Min(paginaActual * itemsPorPagina, _turnos.Count)
                de @_turnos.Count
            </MudText>
            <MudPagination Count="@totalPaginasTurnos"
                           Selected="@paginaActual"
                           SelectedChanged="CambiarPagina" />
        </MudStack>
    };

    private RenderFragment RenderPropuestas() => __builder =>
    {
        paginaActual = 1;

        if (cargando)
        {
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-6">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">Cargando propuestas...</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>;
            return;
        }

        if (esTesorero)
        {
            @RenderPropuestasVistaTesorero();
        }
        else
        {
            @RenderPropuestasVistaProTesorero();
        }
    };

    private RenderFragment RenderTurnosVistaTesorero() => __builder =>
    {
        int i = 1;
        <MudStack Spacing="3" Class="my-4">
            @foreach (var turno in turnosPaginados)
            {
                <MudCard Elevation="2" Class="rounded-lg hover-scale">
                    <MudCardContent Class="pa-4">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                            <MudStack Spacing="2" Class="flex-grow-1">
                                <MudStack Spacing="1">
                                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                        <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                                        Turno #@(i++)
                                    </MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                                        <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                        <b>Fecha:</b> @(turno.turnoDTO.Fecha?.ToString("dd/MM/yyyy")) - @(turno.turnoDTO.HoraInicio?.ToString(@"hh\:mm"))
                                    </MudText>
                                </MudStack>
                            </MudStack>

                            <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                <MudTooltip Text="Pedir cambio de turno">
                                    <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                                   Size="Size.Medium"
                                                   Color="Color.Success"
                                                   Variant="Variant.Filled"
                                                   OnClick="@(() => PedirCambio(turno.turnoDTO.IdTurno))" />
                                </MudTooltip>
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    };

    private RenderFragment RenderTurnosVistaProTesorero() => __builder =>
    {
        <MudStack Spacing="3" Class="my-4">

            <!-- Filtro de búsqueda por tesorero -->
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.Search" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                            Filtrar por Tesorero
                        </MudText>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudSelect T="int?"
                                       Label="Buscar por tesorero"
                                       @bind-Value="tesoreroSeleccionado"
                                       Variant="Variant.Outlined"
                                       Clearable="true"
                                       Class="flex-grow-1">
                                <MudSelectItem T="int?" Value="null">Todos los tesoreros</MudSelectItem>
                                @foreach (var tesorero in _tesoreros)
                                {
                                    <MudSelectItem T="int?" Value="@tesorero.IdTesorero">
                                        @tesorero.Nombre
                                    </MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.Search"
                                       OnClick="FiltrarTurnosPorTesorero">
                                Filtrar
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>

            <!-- Lista de turnos filtrados -->
            @if (turnosPaginados.Any())
            {
                int i = 1;
                @foreach (var turno in turnosPaginados)
                {
                    <MudCard Elevation="2" Class="rounded-lg hover-scale">
                        <MudCardContent Class="pa-4">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="2" Class="flex-grow-1">
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                                            Turno #@(i++)
                                        </MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Info">
                                            <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                            <b>Tesorero:</b> @ObtenerNombreTesorero(turno.turnoDTO.IdTesorero)
                                        </MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Info">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                            <b>Fecha:</b> @(turno.turnoDTO.Fecha?.ToString("dd/MM/yyyy")) - @(turno.turnoDTO.HoraInicio?.ToString(@"hh\:mm"))
                                        </MudText>
                                    </MudStack>
                                </MudStack>

                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    @if(turno.turnoDTO.IdTesorero == idTesorero)
                                    {
                                        <MudTooltip Text="Pedir cambio de turno">
                                            <MudIconButton Icon="@Icons.Material.Filled.SwapHoriz"
                                                           Size="Size.Medium"
                                                           Color="Color.Success"
                                                           Variant="Variant.Filled"
                                                           OnClick="@(() => PedirCambio(turno.turnoDTO.IdTurno))" />
                                        </MudTooltip>
                                    }

                                    @if (!esAuditor)
                                    {
                                        <MudTooltip Text="Editar turno">
                                            <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                                           Size="Size.Medium"
                                                           Color="Color.Primary"
                                                           Variant="Variant.Filled"
                                                           OnClick="@(() => EditarTurno(turno.turnoDTO))" />
                                        </MudTooltip>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            }
            else
            {
                <MudCard Elevation="2" Class="rounded-lg">
                    <MudCardContent>
                        <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-4">
                            <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.5;" />
                            <MudText Typo="Typo.h6" Color="Color.Secondary">No se encontraron turnos para el filtro seleccionado</MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    };

    private RenderFragment RenderPropuestasVistaTesorero() => __builder =>
    {
        if (_propuestas.Count == 0 && !cargando)
        {
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-6">
                        <MudIcon Icon="@Icons.Material.Filled.NotificationsNone" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.5;" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">No hay propuestas de cambio pendientes</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            Las propuestas de cambio aparecerán aquí cuando otros tesoreros soliciten intercambios
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>;
            return;
        }
        <MudStack Spacing="3" Class="my-4">
            @foreach (var propuesta in _propuestas)
            {
                <MudCard Elevation="2" Class="rounded-lg hover-scale">
                    <MudCardContent Class="pa-4">
                        <MudStack Spacing="3">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudStack Spacing="2" Class="flex-grow-1">
                                    <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                        <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                                        Propuesta #@propuesta.IdPropuestaDeCambio
                                    </MudText>
                                    <MudStack Spacing="1">
                                        <MudText Typo="Typo.body2">
                                            <b>Estado:</b>
                                            <MudChip T="string"
                                                     Color="Color.Warning"
                                                     Size="Size.Small"
                                                     Class="ml-2">
                                                @propuesta.Estado
                                            </MudChip>
                                        </MudText>
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">
                                            <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                            <b>Fecha solicitud:</b> @(propuesta.FechaSolicitud.ToString("dd/MM/yyyy HH:mm"))
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <MudTooltip Text="Aceptar propuesta">
                                        <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                       Size="Size.Medium"
                                                       Color="Color.Success"
                                                       Variant="Variant.Filled"
                                                       OnClick="@(() => ActualizarPropuesta(propuesta, "Aceptada"))" />
                                    </MudTooltip>
                                    <MudTooltip Text="Rechazar propuesta">
                                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                       Size="Size.Medium"
                                                       Color="Color.Error"
                                                       Variant="Variant.Filled"
                                                       OnClick="@(() => ActualizarPropuesta(propuesta, "Rechazada"))" />
                                    </MudTooltip>
                                </MudStack>
                            </MudStack>

                            <MudDivider />
                            
                            <MudStack Spacing="2">
                                <MudButton Size="Size.Small" 
                                           StartIcon="@Icons.Material.Filled.Info"
                                           Variant="Variant.Text"
                                           OnClick="@(() => CargarTurno(propuesta.TurnoActual))">
                                    Ver detalles del turno
                                </MudButton>
                                
                                @if (turnoCargado != null && turnoCargado.IdTurno == propuesta.TurnoActual)
                                {
                                    <MudDivider />
                                    <MudGrid>
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.body2">
                                                <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Class="mr-1" />
                                                <b>Fecha:</b> @(turnoCargado.Fecha?.ToString("dd/MM/yyyy") ?? "N/A")
                                            </MudText>
                                        </MudItem>
                                        <MudItem xs="12" sm="6">
                                            <MudText Typo="Typo.body2">
                                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                                <b>Horario:</b> @(turnoCargado.HoraInicio?.ToString(@"hh\:mm"))
                                            </MudText>
                                        </MudItem>
                                    </MudGrid>
                                }
                            </MudStack>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }
        </MudStack>
    };
    

    private RenderFragment RenderPropuestasVistaProTesorero() => __builder =>
    {
        if (_propuestasHistorial.Count == 0)
        {
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-6">
                        <MudIcon Icon="@Icons.Material.Filled.History" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.5;" />
                        <MudText Typo="Typo.h6" Color="Color.Secondary">No hay propuestas en el historial</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary" Align="Align.Center">
                            El historial de propuestas aparecerá aquí una vez que se realicen solicitudes
                        </MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>;
            return;
        }
        <!-- Vista para Protesorero/Admin - Historial de propuestas -->
        <MudStack Spacing="3" Class="my-4">
            <!-- Filtro por estado -->
            <MudCard Elevation="2" Class="rounded-lg">
                <MudCardContent>
                    <MudStack Spacing="3">
                        <MudText Typo="Typo.h6">
                            <MudIcon Icon="@Icons.Material.Filled.FilterList" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                            Filtrar por Estado
                        </MudText>
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudSelect T="string"
                                       Label="Filtrar por estado"
                                       @bind-Value="filtroEstado"
                                       Variant="Variant.Outlined"
                                       Class="flex-grow-1">
                                <MudSelectItem T="string" Value="@("Todas")">Todas</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Aceptada")">Aceptadas</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Rechazada")">Rechazadas</MudSelectItem>
                                <MudSelectItem T="string" Value="@("Pendiente")">Pendientes</MudSelectItem>
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       StartIcon="@Icons.Material.Filled.FilterList"
                                       OnClick="FiltrarPropuestas">
                                Filtrar
                            </MudButton>
                        </MudStack>
                    </MudStack>
                </MudCardContent>
            </MudCard>

            @if (propuestasPaginadas.Any())
            {
                @foreach (var propuesta in propuestasPaginadas)
                {
                    Color chipColor = propuesta.Estado switch
                    {
                        "Aceptada" => Color.Success,
                        "Rechazada" => Color.Error,
                        "Pendiente" => Color.Warning,
                        _ => Color.Default
                    };

                    <MudCard Elevation="2" Class="rounded-lg hover-scale">
                        <MudCardContent Class="pa-4">
                            <MudStack Spacing="3">
                                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                    <MudStack Spacing="2" Class="flex-grow-1">
                                        <MudText Typo="Typo.h6" Style="font-weight: 600;">
                                            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Size="Size.Small" Class="mr-2" Style="color: var(--color-primario);" />
                                            Propuesta #@propuesta.IdPropuestaDeCambio
                                        </MudText>
                                        <MudStack Spacing="1">
                                            <MudText Typo="Typo.body2">
                                                <b>Estado:</b>
                                                <MudChip T="string"
                                                         Color="@chipColor"
                                                         Size="Size.Small"
                                                         Class="ml-2">
                                                    @propuesta.Estado
                                                </MudChip>
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                <MudIcon Icon="@Icons.Material.Filled.Schedule" Size="Size.Small" Class="mr-1" />
                                                <b>Fecha solicitud:</b> @(propuesta.FechaSolicitud.ToString("dd/MM/yyyy HH:mm"))
                                            </MudText>
                                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                                <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                                                <b>Receptor:</b> @ObtenerNombreTesorero(propuesta.IdReceptor)
                                            </MudText>
                                        </MudStack>
                                    </MudStack>
                                    @if (propuesta.Estado.Equals("Pendiente") && propuesta.IdReceptor == idTesorero)
                                    {
                                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                            <MudTooltip Text="Aceptar propuesta">
                                                <MudIconButton Icon="@Icons.Material.Filled.Check"
                                                               Size="Size.Medium"
                                                               Color="Color.Success"
                                                               Variant="Variant.Filled"
                                                               OnClick="@(() => ActualizarPropuesta(propuesta, "Aceptada"))" />
                                            </MudTooltip>
                                            <MudTooltip Text="Rechazar propuesta">
                                                <MudIconButton Icon="@Icons.Material.Filled.Close"
                                                               Size="Size.Medium"
                                                               Color="Color.Error"
                                                               Variant="Variant.Filled"
                                                               OnClick="@(() => ActualizarPropuesta(propuesta, "Rechazada"))" />
                                            </MudTooltip>
                                        </MudStack>
                                    }
                                </MudStack>
                            </MudStack>
                        </MudCardContent>
                    </MudCard>
                }
            }
            else
            {
                <MudCard Elevation="2" Class="rounded-lg">
                    <MudCardContent>
                        <MudStack Spacing="3" AlignItems="AlignItems.Center" Class="py-4">
                            <MudIcon Icon="@Icons.Material.Filled.FilterListOff" Size="Size.Large" Color="Color.Secondary" Style="opacity: 0.5;" />
                            <MudText Typo="Typo.h6" Color="Color.Secondary">No hay propuestas @(filtroEstado != "Todas" ? filtroEstado.ToLower() + "s" : "en el historial")</MudText>
                        </MudStack>
                    </MudCardContent>
                </MudCard>
            }

            <!-- Paginación para propuestas -->
            @if (propuestasPaginadas.Any())
            {
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mt-4">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        Mostrando @((paginaActual - 1) * itemsPorPagina + 1) a
                        @Math.Min(paginaActual * itemsPorPagina, _propuestasHistorial.Count)
                        de @_propuestasHistorial.Count
                    </MudText>
                    <MudPagination Count="@totalPaginasPropuestas"
                                   Selected="@paginaActual"
                                   SelectedChanged="CambiarPaginaPropuestas" />
                </MudStack>
            }
        </MudStack>
    };
}
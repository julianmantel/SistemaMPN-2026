@using MudBlazor
@using SistemaMPN.Shared.DTO
@inject IDialogService DialogService

<EditForm Model="propuesta" OnValidSubmit="Guardar">
    <MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Asignar Propuesta de Cambio</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="border: 1px solid var(--mud-palette-divider);">
                    <MudText Typo="Typo.subtitle2" Class="mb-3" Color="Color.Primary">
                        <MudIcon Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="mr-1" />
                        Tesorero receptor *
                    </MudText>
                    <MudAutocomplete T="string"
                                     Label="Seleccione un tesorero"
                                     Value="@nombreSeleccionado"
                                     ValueChanged="(string nombreTesorero) => CargarTesoreroSeleccionado(nombreTesorero)"
                                     Variant="Variant.Outlined"
                                     SearchFunc="Search1"
                                     ToStringFunc="@(x => x)"
                                     Clearable="true"
                                     Required="true" />
                </MudPaper>
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="Cancelar"
                       Color="Color.Default"
                       Variant="Variant.Outlined">
                Cancelar
            </MudButton>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       ButtonType="ButtonType.Submit"
                       StartIcon="@Icons.Material.Filled.Check">
                @ButtonText
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public string? ButtonText { get; set; }
    [Parameter] public List<TesoreroDisponibleDTO> tesoreros { get; set; }
    [Parameter] public int Turno { get; set; }

    private PropuestaDeCambioDTO propuesta = new();
    private int selectedTesoreroId;
    private string? nombreSeleccionado;

    private void Guardar()
    {
        if (selectedTesoreroId == 0)
        {
            MudDialog.Cancel();
            return;
        }

        propuesta.IdReceptor = selectedTesoreroId;
        propuesta.TurnoActual = Turno;

        MudDialog.Close(DialogResult.Ok(propuesta));
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }

    private async Task<IEnumerable<string>> Search1(String value, CancellationToken token)
    {
        await Task.Delay(5, token);

        if (string.IsNullOrEmpty(value))
            return tesoreros?.Select(x => x.Nombre).ToList() ?? new List<string>();

        return tesoreros?.Where(x => x.Nombre.Contains(value, StringComparison.InvariantCultureIgnoreCase))
                      .Select(x => x.Nombre)
                      .AsEnumerable()
           ?? new List<string>();
    }

    private async Task CargarTesoreroSeleccionado(string? nombreTesorero)
    {
        nombreSeleccionado = nombreTesorero;
        if (tesoreros == null) return;

        var seleccionado = tesoreros.FirstOrDefault(g => g.Nombre.Equals(nombreTesorero));
        if (seleccionado != null)
        {
            selectedTesoreroId = seleccionado.IdTesorero;
        }

        StateHasChanged();
    }
}

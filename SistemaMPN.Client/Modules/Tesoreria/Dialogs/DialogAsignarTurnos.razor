@using MudBlazor
@using SistemaMPN.Client.Modules.Tesoreria.ViewModels
@using SistemaMPN.Shared.DTO

@inject IDialogService DialogService
@inject HttpClient Http

<MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Event" Color="Color.Primary" />
            <MudText Typo="Typo.h6">Asignar Turnos</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="3">
            @for (int i = 0; i < _turnosAsignados.Count; i++)
            {
                var index = i;
                <MudPaper Elevation="0" Class="pa-4 rounded-lg" Style="border: 1px solid var(--mud-palette-divider);">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-2">
                        <MudText Typo="Typo.subtitle1">
                            <MudIcon Icon="@Icons.Material.Filled.Event" Size="Size.Small" Color="Color.Primary" Class="mr-1" />
                            Turno #@(index + 1)
                        </MudText>
                        <MudIconButton Size="Size.Small"
                                       Color="Color.Error"
                                       Icon="@Icons.Material.Filled.Delete"
                                       OnClick="() => EliminarTurno(index)">
                        </MudIconButton>
                    </MudStack>
                    <MudGrid Spacing="2">
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Info">Tesorero</MudText>
                            <MudText Typo="Typo.body1">@(ObtenerNombreTesorero(_turnosAsignados[index].IdTesorero))</MudText>
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudText Typo="Typo.caption" Color="Color.Info">Fecha</MudText>
                            <MudText Typo="Typo.body1">@(_turnosAsignados[index].Fecha?.ToString("dd/MM/yyyy"))</MudText>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            }

            @if (_turnosAsignados.Count == 0)
            {
                <MudPaper Elevation="0" Class="pa-6 rounded-lg" Style="border: 1px dashed var(--mud-palette-divider);">
                    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Spacing="2">
                        <MudIcon Icon="@Icons.Material.Filled.EventBusy" Size="Size.Large" Color="Color.Secondary" />
                        <MudText Typo="Typo.body1" Color="Color.Secondary">
                            No hay turnos asignados aún
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Default">
                            Utilice el botón de abajo para añadir turnos
                        </MudText>
                    </MudStack>
                </MudPaper>
            }

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Add"
                       OnClick="AsignarTurno"
                       FullWidth="true">
                Añadir turno
            </MudButton>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar"
                   Color="Color.Default"
                   Variant="Variant.Outlined">
            Cancelar
        </MudButton>
        <MudButton Variant="Variant.Filled"
                   Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Check"
                   OnClick="Aceptar">
            Asignar turnos
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public List<TesoreroDisponibleDTO> tesoreros { get; set; }

    private List<TurnoDTO> _turnosAsignados = new List<TurnoDTO>();

    public async Task AsignarTurno()
    {
        var parameters = new DialogParameters<DialogTurno>();
        parameters.Add(x => x.Turno, new TurnoDTO());
        parameters.Add(x => x.tesoreros, tesoreros);

        var result = await DialogService.ShowAsync<DialogTurno>("Asignar Turnos",
                                                                parameters,
                                                                new DialogOptions
                                                                    {
                                                                        MaxWidth = MaxWidth.Small,
                                                                        FullWidth = true,
                                                                        BackdropClick = false,
                                                                        CloseOnEscapeKey = false
                                                                    });
        var dialogResult = await result.Result;
        if (!dialogResult.Canceled && dialogResult.Data is TurnoDTO turnoNuevo)
        {
            _turnosAsignados.Add(turnoNuevo);
            StateHasChanged();
        }
    }

    public async Task EliminarTurno(int index)
    {
        if (index >= 0 && index < _turnosAsignados.Count)
        {
            _turnosAsignados.RemoveAt(index);
        }
        StateHasChanged();
    }

    private string ObtenerNombreTesorero(int idTesoreroBusqueda)
    {
        var tesorero = tesoreros.FirstOrDefault(t => t.IdTesorero == idTesoreroBusqueda);
        return tesorero != null ? $"{tesorero.Nombre}" : "Desconocido";
    }

    private async Task Aceptar()
    {
        MudDialog.Close(DialogResult.Ok(_turnosAsignados));
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}

    private async Task HandleHttpError(HttpResponseMessage response)
    {
        switch (response.StatusCode)
        {
            case HttpStatusCode.NotFound:
                errorMessage = $"No se encontró el miembro con ID {id}";
                Snackbar.Add(errorMessage, Severity.Warning);
                Nav.NavigateTo("/miembros/listadoMiembros");
                break;
            default:
                errorMessage = $"Error del servidor: {response.StatusCode}";
                var defaultContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"{errorMessage}: {defaultContent}", Severity.Error);
                break;
        }
    }

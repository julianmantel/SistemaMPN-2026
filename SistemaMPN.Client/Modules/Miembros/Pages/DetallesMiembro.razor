@code {

    string? FotoUrl;
    string? FotoPreviewUrl;
    IBrowserFile? fotoSeleccionada;
    bool subiendoFoto = false;

    // Diccionario para controlar el estado de expansión de los paneles
    private Dictionary<string, bool> expandedPanels = new Dictionary<string, bool>
    {
        { "basica", false },
        { "salud", false },
        { "academica", false },
        { "laboral", false },
        { "direccion", false },
        { "eclesiastica", false },
        { "personal", false }
    };

    private List<string> nacionalidades = new();

    private async Task VolverAtras()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    async Task OnFotoSelected(IBrowserFile? file)
    {
        try
        {
            if (file == null)
            {
                await EliminarFotoPreview();
                return;
            }

            if (string.IsNullOrWhiteSpace(miembroEditable.info_basica_miembro.dni))
            {
                Snackbar.Add("Primero ingresa el DNI para nombrar la foto.", Severity.Warning);
                return;
            }

            if (!string.Equals(file.ContentType, "image/jpeg", StringComparison.OrdinalIgnoreCase))
            {
                Snackbar.Add("La foto debe ser JPG (image/jpeg).", Severity.Error);
                return;
            }

            // Validar tamaño (máximo 5MB)
            if (file.Size > 5 * 1024 * 1024)
            {
                Snackbar.Add("La foto no puede superar los 5MB.", Severity.Error);
                return;
            }

            // Guardar el archivo en memoria para subirlo después
            fotoSeleccionada = file;

            // Crear preview local
            var buffer = new byte[file.Size];
            await file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).ReadAsync(buffer);
            var base64 = Convert.ToBase64String(buffer);
            FotoPreviewUrl = $"data:image/jpeg;base64,{base64}";

            MarkSectionAsModified("basica");
            Snackbar.Add("Foto seleccionada. Presiona 'Guardar' para confirmar.", Severity.Info);
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al seleccionar foto: {ex.Message}", Severity.Error);
        }
    }

    async Task EliminarFotoPreview()
    {
        fotoSeleccionada = null;
        FotoPreviewUrl = null;
        // No marcar como modificado si solo se limpia el preview
        StateHasChanged();
    }


    // En tu @code block
    private long FotoTimestamp; // Timestamp para forzar re-render de la imagen
    private bool isLoadingFoto = true;
    private async Task RefreshFoto()
    {
        // Solo actualizamos isLoadingFoto si es la primera carga
        if (string.IsNullOrWhiteSpace(FotoUrl))
        {
            isLoadingFoto = true;
            StateHasChanged(); // 👈 Solo la primera vez para mostrar skeleton
        }

        var id = miembro?.id;
        if (id == null || id <= 0)
        {
            FotoUrl = null;
            isLoadingFoto = false;
            return; // 👈 Sin StateHasChanged() aquí
        }

        try
        {
            var response = await Http.GetAsync($"api/miembros/{id}/foto");
            if (response.IsSuccessStatusCode)
            {
                var bytes = await response.Content.ReadAsByteArrayAsync();
                var contentType = response.Content.Headers.ContentType?.MediaType ?? "image/jpeg";
                var newFotoUrl = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";

                // 👇 Solo actualizamos si la foto cambió realmente
                if (newFotoUrl != FotoUrl)
                {
                    FotoUrl = newFotoUrl;
                    FotoTimestamp = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
                    // 👈 NO llamamos a StateHasChanged() aquí: @key + @bind-Expanded se encargan
                }
            }
            else
            {
                if (FotoUrl != null) // Solo si había foto y ahora no hay
                {
                    FotoUrl = null;
                    // 👈 Tampoco StateHasChanged() aquí
                }
            }
        }
        catch
        {
            if (FotoUrl != null)
            {
                FotoUrl = null;
            }
        }
        finally
        {
            // Solo actualizamos isLoadingFoto si estaba en true
            if (isLoadingFoto)
            {
                isLoadingFoto = false;
                StateHasChanged(); // 👈 Único StateHasChanged() necesario al finalizar carga inicial
            }
        }
    }

    private string GetPlaceholder()
        => miembro.info_basica_miembro.sexo == 'F'
           ? "/images/placeholder_femenino.png"
           : miembro.info_basica_miembro.sexo == 'M'
             ? "/images/placeholder_masculino.png"
             : "/images/avatar-placeholder.png";

    private string GetSrc() => string.IsNullOrWhiteSpace(FotoUrl) ? GetPlaceholder() : FotoUrl;

    private string? GetOnErrorJs()
        => string.IsNullOrWhiteSpace(FotoUrl)
           ? null
           : $"this.onerror=null;this.src='{GetPlaceholder()}';";

    [Parameter]
    public int id { get; set; }

    // Estados originales
    private MiembroDTO miembro = new MiembroDTO();
    private bool isLoading = true;
    private string errorMessage = string.Empty;

    // Estados para edición
    private MiembroDTO miembroOriginal = new MiembroDTO(); // Backup para cancelar
    private MiembroDTO miembroEditable = new MiembroDTO(); // Copia editable
    private HashSet<string> editingSections = new HashSet<string>();
    private HashSet<string> modifiedSections = new HashSet<string>();
    private bool hasUnsavedChanges = false;
    private bool isSaving = false;

    // Estados para campos dinámicos
    private HashSet<object> selectedAlergias = new HashSet<object>();
    private string nuevaAlergia = "";
    private string nuevaCondicionMedica = "";
    private string nuevoMedicamento = "";

    private string? mensajePeticion;
    private bool vieneDePeticion = false;
    private bool mostrarMensajePeticion = false;

    protected override async Task OnInitializedAsync()
    {
        nacionalidades = (await NacionalidadesService.GetAsync()).ToList(); //carga select de paises
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await auth.GetAuthenticationStateAsync();
            await CargarDatosPeticion();
            await LoadMiembro();
        }
    }

    private async Task CargarDatosPeticion()
    {
        var uri = new Uri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("idPeticion", out var idStr) && int.TryParse(idStr, out var idPeticion))
        {
            try
            {
                var response = await Http.GetFromJsonAsync<JsonElement>($"api/peticion/GetPeticionDetalle/{idPeticion}");
                var tipo = response.GetProperty("tipo").GetString();
                var estado = response.GetProperty("estado").GetString();

                if (tipo == "Actualizacion" && estado == "Aceptada" && response.TryGetProperty("mensaje", out var msg) && msg.ValueKind != JsonValueKind.Null)
                {
                    mensajePeticion = msg.GetString();
                    vieneDePeticion = true;
                    Snackbar.Add("Esta petición contiene actualizaciones solicitadas por el líder", Severity.Info);
                }
                StateHasChanged();
            }
            catch (Exception ex)
            {
                Snackbar.Add($"Error al cargar datos de la petición: {ex.Message}", Severity.Warning);
            }
        }
    }


    private async Task LoadMiembro()
    {
        try
        {
            isLoading = true;
            isLoadingFoto = true; // 👈 Reiniciar estado de carga de foto
            StateHasChanged();

            var response = await Http.GetAsync($"api/miembros/GetInfoMiembro/{id}");

            if (response.IsSuccessStatusCode)
            {
                miembro = await response.Content.ReadFromJsonAsync<MiembroDTO>();
                if (miembro == null)
                {
                    errorMessage = "Error al deserializar los datos del miembro";
                    Snackbar.Add(errorMessage, Severity.Error);
                    isLoadingFoto = false; // 👈 No hay foto si no hay miembro
                }
                else
                {
                    miembroOriginal = DeepCopy(miembro);
                    miembroEditable = DeepCopy(miembro);
                    await RefreshFoto(); // 👈 RefreshFoto maneja isLoadingFoto internamente
                }
            }
            else
            {
                await HandleHttpError(response);
                isLoadingFoto = false;
            }
        }
        catch (HttpRequestException httpEx)
        {
            errorMessage = "Error de conexión con el servidor";
            Snackbar.Add($"{errorMessage}: {httpEx.Message}", Severity.Error);
            isLoadingFoto = false;
        }
        catch (Exception ex)
        {
            errorMessage = "Error inesperado al cargar el miembro";
            Snackbar.Add($"{errorMessage}: {ex.Message}", Severity.Error);
            isLoadingFoto = false;
        }
        finally
        {
            isLoading = false;
            // 👇 NO pongas StateHasChanged() aquí si RefreshFoto ya lo hizo en su finally
            if (!isLoadingFoto) StateHasChanged();
        }
    }

     // Métodos de control de edición
    private void StartEditSection(string section)
    {
        editingSections.Add(section);
        StateHasChanged();
    }

    private void OnEditSectionRequested(string section)
    {
        // Expandir el panel si no está expandido
        if (!expandedPanels[section])
        {
            expandedPanels[section] = true;
            StateHasChanged();
        }
    }

    private void CancelSectionEdit(string section)
    {
        editingSections.Remove(section);
        modifiedSections.Remove(section);

        // Si es la sección básica, limpiar la foto seleccionada
        if (section == "basica")
        {
            fotoSeleccionada = null;
            FotoPreviewUrl = null;
        }

        // Restaurar datos originales para esta sección
        RestoreSectionData(section);

        UpdateGlobalState();
        StateHasChanged();
    }

    private async Task SaveSection(string section)
    {
        try
        {
            isSaving = true;

            if (!ValidateSection(section))
            {
                Snackbar.Add("Por favor corrige los errores antes de guardar", Severity.Error);
                return;
            }

            // Si es la sección básica y hay foto seleccionada, subirla primero
            if (section == "basica" && fotoSeleccionada != null)
            {
                subiendoFoto = true;
                StateHasChanged();

                try
                {
                    using var form = new MultipartFormDataContent();

                    var stream = fotoSeleccionada.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                    var fileContent = new StreamContent(stream);

                    fileContent.Headers.ContentType =
                        new System.Net.Http.Headers.MediaTypeHeaderValue(fotoSeleccionada.ContentType);

                    // IMPORTANTE: nombre del campo = "foto"
                    form.Add(fileContent, "foto", fotoSeleccionada.Name);

                    var resp = await Http.PostAsync(
                        $"api/miembros/{miembroEditable.id}/foto",
                        form);

                    if (!resp.IsSuccessStatusCode)
                    {
                        var errorContent = await resp.Content.ReadAsStringAsync();
                        Snackbar.Add($"Error subiendo foto: {errorContent}", Severity.Error);
                        return;
                    }

                    fotoSeleccionada = null;
                    FotoPreviewUrl = null;
                    await RefreshFoto();
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error al subir foto: {ex.Message}", Severity.Error);
                }
                finally
                {
                    subiendoFoto = false;
                }
            }

            // Guardar la sección como antes
            var sectionData = GetSectionData(section);
            var response = await Http.PatchAsJsonAsync(
                $"api/miembros/actualizarmiembro/{id}/seccion/{section}",
                sectionData);

            if (response.IsSuccessStatusCode)
            {
                UpdateOriginalSectionData(section);
                editingSections.Remove(section);
                modifiedSections.Remove(section);

                // Si se guardó la sección básica, refrescar la foto
                if (section == "basica")
                {
                    FotoPreviewUrl = null;
                    await RefreshFoto();
                }

                Snackbar.Add($"Sección '{GetSectionDisplayName(section)}' guardada exitosamente", Severity.Success);
                UpdateGlobalState();
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Error al guardar: {errorContent}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private async Task SaveAllChanges()
    {
        try
        {
            if (modifiedSections.Count == 0)
            {
                Snackbar.Add("No hay cambios para guardar", Severity.Info);
                return;
            }

            isSaving = true;
            StateHasChanged();

            // Guardar cada sección que fue modificada usando su endpoint específico
            var seccionesGuardadas = new List<string>();
            var erroresGuardar = new List<string>();

            foreach (var section in modifiedSections.ToList())
            {
                if (!SectionHasRealChanges(section))
                    continue;

                if (!ValidateSection(section))
                {
                    erroresGuardar.Add($"{GetSectionDisplayName(section)}: Por favor corrige los errores");
                    continue;
                }

                try
                {
                    // Si es la sección básica y hay foto seleccionada, subirla primero
                    if (section == "basica" && fotoSeleccionada != null)
                    {
                        subiendoFoto = true;
                        StateHasChanged();

                        try
                        {
                            using var form = new MultipartFormDataContent();

                            var stream = fotoSeleccionada.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
                            var fileContent = new StreamContent(stream);

                            fileContent.Headers.ContentType =
                                new System.Net.Http.Headers.MediaTypeHeaderValue(fotoSeleccionada.ContentType);

                            form.Add(fileContent, "foto", fotoSeleccionada.Name);

                            var resp = await Http.PostAsync(
                                $"api/miembros/{miembroEditable.id}/foto",
                                form);

                            if (!resp.IsSuccessStatusCode)
                            {
                                var errorContent = await resp.Content.ReadAsStringAsync();
                                erroresGuardar.Add($"Error subiendo foto: {errorContent}");
                                continue;
                            }

                            fotoSeleccionada = null;
                            FotoPreviewUrl = null;
                            await RefreshFoto();
                        }
                        catch (Exception ex)
                        {
                            erroresGuardar.Add($"Error al subir foto: {ex.Message}");
                            continue;
                        }
                        finally
                        {
                            subiendoFoto = false;
                        }
                    }

                    // Guardar la sección usando su endpoint específico
                    var sectionData = GetSectionData(section);
                    var response = await Http.PatchAsJsonAsync(
                        $"api/miembros/actualizarmiembro/{id}/seccion/{section}",
                        sectionData);

                    if (response.IsSuccessStatusCode)
                    {
                        UpdateOriginalSectionData(section);
                        editingSections.Remove(section);
                        modifiedSections.Remove(section);

                        // Si se guardó la sección básica, refrescar la foto
                        if (section == "basica")
                        {
                            FotoPreviewUrl = null;
                            await RefreshFoto();
                        }

                        seccionesGuardadas.Add(GetSectionDisplayName(section));
                    }
                    else
                    {
                        var errorContent = await response.Content.ReadAsStringAsync();
                        erroresGuardar.Add($"{GetSectionDisplayName(section)}: {errorContent}");
                    }
                }
                catch (Exception ex)
                {
                    erroresGuardar.Add($"{GetSectionDisplayName(section)}: {ex.Message}");
                }
            }

            // Mostrar resultados
            if (seccionesGuardadas.Any())
            {
                Snackbar.Add($"✓ Guardadas: {string.Join(", ", seccionesGuardadas)}", Severity.Success);
            }

            if (erroresGuardar.Any())
            {
                foreach (var error in erroresGuardar)
                {
                    Snackbar.Add($"✗ {error}", Severity.Error);
                }
            }

            UpdateGlobalState();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }

    private void CancelAllChanges()
    {
        miembroEditable = DeepCopy(miembroOriginal);
        editingSections.Clear();
        modifiedSections.Clear();
        hasUnsavedChanges = false;
        StateHasChanged();
    }

    // Métodos de validación
    private string ValidarFechaNacimiento(DateTime? fecha)
    {
        if (fecha == null) return null;
        if (fecha > DateTime.Today.AddYears(-16))
            return "El miembro debe tener al menos 16 años";
        if (fecha < DateTime.Today.AddYears(-120))
            return "Fecha de nacimiento inválida";
        return null;
    }

    private bool SectionHasRealChanges(string section)
    {
        try
        {
            var originalJson = System.Text.Json.JsonSerializer.Serialize(GetSectionData(section));
            var editableJson = System.Text.Json.JsonSerializer.Serialize(GetSectionDataFromOriginal(section));
            return originalJson != editableJson;
        }
        catch
        {
            // Si hay error en la comparación, asumir que hay cambios
            return true;
        }
    }

    private object GetSectionDataFromOriginal(string section)
    {
        return section switch
        {
            "basica" => miembroOriginal.info_basica_miembro,
            "salud" => miembroOriginal.info_salud,
            "academica" => miembroOriginal.info_academica,
            "laboral" => miembroOriginal.info_laboral,
            "direccion" => miembroOriginal.direccion,
            "eclesiastica" => miembroOriginal.info_eclesiastica,
            "personal" => miembroOriginal.info_personal,
            _ => null
        };
    }

    private bool ValidateSection(string section)
    {
        switch (section)
        {
            case "basica":
                return !string.IsNullOrEmpty(miembroEditable.info_basica_miembro.nombre) &&
                       !string.IsNullOrEmpty(miembroEditable.info_basica_miembro.apellido);

            case "direccion":
                return !string.IsNullOrEmpty(miembroEditable.direccion.calle) &&
                       miembroEditable.direccion.altura != null;

            case "personal":
                // Validar que los hijos tengan nombre y apellido si existen
                if (miembroEditable.info_personal.hijos != null)
                {
                    return miembroEditable.info_personal.hijos.All(h => 
                        !string.IsNullOrEmpty(h.nombre) && !string.IsNullOrEmpty(h.apellido));
                }
                return true;

            case "eclesiastica":
                // Validar coherencia de fechas de bautismo
                if (miembroEditable.info_eclesiastica.realizo_bautismo == true &&
                    miembroEditable.info_eclesiastica.fecha_de_bautismo != null &&
                    miembroEditable.info_basica_miembro.fecha_nacimiento != null)
                {
                    return miembroEditable.info_eclesiastica.fecha_de_bautismo >= 
                           miembroEditable.info_basica_miembro.fecha_nacimiento.Value.Year;
                }
                return true;

            default:
                return true;
        }
    }

    private void MarkSectionAsModified(string section)
    {
        modifiedSections.Add(section);
        UpdateGlobalState();
    }

    private string GetSectionDisplayName(string section)
    {
        return section switch
        {
            "basica" => "Información Básica",
            "salud" => "Información de Salud",
            "academica" => "Información Académica",
            "laboral" => "Información Laboral",
            "direccion" => "Información de Dirección",
            "eclesiastica" => "Información Eclesiástica",
            "personal" => "Información Personal",
            _ => section
        };
    }

    private void UpdateGlobalState()
    {
        hasUnsavedChanges = editingSections.Any() || modifiedSections.Any();
    }


    private MiembroDTO DeepCopy(MiembroDTO original)
    {
        // Implementar deep copy (puede usar JSON serialization o librería)
        var json = System.Text.Json.JsonSerializer.Serialize(original);
        return System.Text.Json.JsonSerializer.Deserialize<MiembroDTO>(json);
    }

    // Métodos de validación adicionales
    private string ValidarFechaBautismo(int? fechaBautismo)
    {
        if (fechaBautismo == null) return null;

        if (miembroEditable.info_basica_miembro.fecha_nacimiento != null &&
            fechaBautismo < miembroEditable.info_basica_miembro.fecha_nacimiento.Value.Year)
        {
            return "La fecha de bautismo no puede ser anterior a la fecha de nacimiento";
        }

        if (fechaBautismo > DateTime.Now.Year)
        {
            return "La fecha de bautismo no puede ser futura";
        }

        return null;
    }

    private string ValidarDNIOptional(string dni)
    {
        if (string.IsNullOrWhiteSpace(dni)) return null; // Es opcional

        if (!dni.All(char.IsDigit)) return "El DNI debe contener solo números";
        if (dni.Length < 7 || dni.Length > 8) return "El DNI debe tener entre 7 y 8 dígitos";

        return null;
    }


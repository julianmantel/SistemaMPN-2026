                                            <MudTextField @bind-Value="miembroEditable.info_eclesiastica.lugar_bautismo"
                                                          Label="Lugar de Bautismo"
                                                          Variant="Variant.Outlined"
                                                          Placeholder="Iglesia o lugar donde fue bautizado"
                                                          @bind-Value:after="@(() => MarkSectionAsModified("eclesiastica"))"
                                                          For="@(() => miembroEditable.info_eclesiastica.lugar_bautismo)" />
                                        </MudItem>
                                    }
                                    <!-- Editor de Seminarios -->
                                    <MudItem xs="12">
                                        <MudText Typo="Typo.subtitle1" Class="mb-3">Seminarios Realizados</MudText>


    // Método extendido para actualizar datos originales
    private void UpdateOriginalSectionData(string section)
    {
        switch (section)
        {
            case "basica":
                miembroOriginal.info_basica_miembro = DeepCopy(miembroEditable).info_basica_miembro;
                miembro.info_basica_miembro = miembroEditable.info_basica_miembro;
                break;
            case "salud":
                miembroOriginal.info_salud = DeepCopy(miembroEditable).info_salud;
                miembro.info_salud = miembroEditable.info_salud;
                miembro.info_salud.tiene_informacion_salud = true;
                break;
            case "academica":
                miembroOriginal.info_academica = DeepCopy(miembroEditable).info_academica;
                miembro.info_academica = miembroEditable.info_academica;
                miembro.info_academica.tiene_informacion_academica = true;
                break;
            case "laboral":
                miembroOriginal.info_laboral = DeepCopy(miembroEditable).info_laboral;
                miembro.info_laboral = miembroEditable.info_laboral;
                miembro.info_laboral.tiene_informacion_laboral = true;
                break;
            case "direccion":
                miembroOriginal.direccion = DeepCopy(miembroEditable).direccion;
                miembro.direccion = miembroEditable.direccion;
                miembro.direccion.tiene_direccion = true;
                break;
            case "eclesiastica":
                miembroOriginal.info_eclesiastica = DeepCopy(miembroEditable).info_eclesiastica;
                miembro.info_eclesiastica = miembroEditable.info_eclesiastica;
                miembro.info_eclesiastica.tiene_informacion_eclesiastica = true;
                break;
            case "personal":
                miembroOriginal.info_personal = DeepCopy(miembroEditable).info_personal;
                miembro.info_personal = miembroEditable.info_personal;
                miembro.info_personal.tiene_informacion_personal = true;
                break;
        }
    }

    private void AddAlergia()
    {
        if (!string.IsNullOrWhiteSpace(nuevaAlergia))
        {
            if (!Regex.IsMatch(nuevaAlergia, @"^(?=.*[A-Za-z])(?=.*\d|.*[A-Za-z]).*\S.*$"))
            {
                Snackbar.Add("El nombre de la alergia debe contener al menos una letra y no puede estar vacío o solo con espacios.", Severity.Error);
                return;
            }

            miembroEditable.info_salud.alergias ??= new List<string>();
            if (!miembroEditable.info_salud.alergias.Contains(nuevaAlergia))
            {
                miembroEditable.info_salud.alergias.Add(nuevaAlergia.Trim());
                modifiedSections.Add("salud");
                UpdateGlobalState();
            }
            nuevaAlergia = "";
            StateHasChanged();
        }
    }


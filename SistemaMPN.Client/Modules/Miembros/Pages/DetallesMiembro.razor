                                                        OnEdit="StartEditSection"
                                                        OnEditRequested="OnEditSectionRequested" />
                                </div>
                            </div>
                            <div class="d-flex">
                                @if (editingSections.Contains("eclesiastica"))
                                {
                                    <MudChip T="string" Color="Color.Info" Size="Size.Small" Class="ml-2">Editando</MudChip>
                                }
                                @if (modifiedSections.Contains("eclesiastica"))
                                {
                                    <MudChip T="string" Color="Color.Warning" Size="Size.Small" Class="ml-2">Cambios pendientes</MudChip>
                                }
                            </div>
                        </TitleContent>
                        <ChildContent>
                            @if (editingSections.Contains("eclesiastica"))
                            {
                                <!-- Modo Edición Eclesiástica -->
                                <EditForm Context="InformacionEclesiastica" Model="miembroEditable.info_eclesiastica" OnValidSubmit='() => SaveSection("eclesiastica")'>
                                <DataAnnotationsValidator />
                                <ValidationSummary />

                                <MudGrid>
                                    <MudItem xs="12" sm="6">
                                        <MudTextField @bind-Value="miembroEditable.info_eclesiastica.convocante"
                                                      Label="Convocante"
                                                      Variant="Variant.Outlined"
                                                      For="@(() => miembroEditable.info_eclesiastica.convocante)"
                                                      Placeholder="Persona que lo invitó a la iglesia"
                                                      @bind-Value:after="@(() => MarkSectionAsModified("eclesiastica"))" />
                                    </MudItem>
                                    <MudItem xs="12" sm="6">
                                        <MudNumericField T="int?"
                                                         @bind-Value="miembroEditable.info_eclesiastica.fecha_desde_la_que_asiste"
                                                         Label="Año desde el que asiste"
                                                         Variant="Variant.Outlined"
                                                         Min="1900"
                                                         Max="@DateTime.Now.Year"
                                                         @bind-Value:after="@(() => MarkSectionAsModified("eclesiastica"))" />
                                    </MudItem>
                                    
                                    <MudItem xs="12">
                                        <MudSwitch @bind-Value="miembroEditable.info_eclesiastica.realizo_bautismo" 
                                                   Label="Bautismo"
                                                   Color="Color.Success"
                                                   UncheckedColor="Color.Default"
                                                   T="bool?"
                                                   @bind-Value:after="@(() => MarkSectionAsModified("eclesiastica"))" />
                                    </MudItem>

                                    @if (miembroEditable.info_eclesiastica.realizo_bautismo != null && miembroEditable.info_eclesiastica.realizo_bautismo.Value)
                                    {
                                        <MudItem xs="12" sm="6">
                                            <MudTextField @bind-Value="miembroEditable.info_eclesiastica.pastor"
                                                          Label="Pastor que lo bautizó"
                                                          Variant="Variant.Outlined"
                                                          @bind-Value:after="@(() => MarkSectionAsModified("eclesiastica"))"
                                                          For="@(() => miembroEditable.info_eclesiastica.pastor)"/>
                                        </MudItem>
                                        <MudItem xs="12" sm="6">
                                            <MudNumericField T="int?"
                                                             @bind-value="miembroEditable.info_eclesiastica.fecha_de_bautismo"
                                                             For="@(() => miembroEditable.info_eclesiastica.fecha_de_bautismo)"
                                                             Label="Fecha de Bautismo"
                                                             Variant="Variant.Outlined"
                                                             Validation="ValidarFechaBautismo" />
                                        </MudItem>

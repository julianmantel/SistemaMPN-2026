@using SistemaMPN.Shared.DTO
@using System.Text.RegularExpressions

@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.LocalPharmacy" Color="Color.Success" />
            <MudText Typo="Typo.h6">Agregar Medicamento</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="nombreMedicamento"
                      Label="Nombre del Medicamento"
                      Variant="Variant.Outlined"
                      Required="true"
                      Immediate="true"
                      Clearable="true"
                      Placeholder="Ingrese el nombre del medicamento..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" 
                   Color="Color.Default" 
                   Variant="Variant.Text">
            Cancelar
        </MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   OnClick="Guardar"
                   Disabled="@(!EsValido())"
                   StartIcon="@Icons.Material.Filled.Check">
            Guardar
        </MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    string nombreMedicamento;

    private void Guardar()
    {
        var data = nombreMedicamento;
        if (string.IsNullOrWhiteSpace(data))
        {
            MudDialog.Cancel();
            return;
        }

        if (!Regex.IsMatch(data, @"^(?=.*[A-Za-z])(?=.*\d|.*[A-Za-z]).*\S.*$"))
        {
            Snackbar.Add("El nombre del medicamento debe contener al menos una letra y no puede estar vacío o solo con espacios.", Severity.Error);
            return;
        }

        MudDialog.Close(DialogResult.Ok(data));
    }

    private bool EsValido()
    {
        return !string.IsNullOrWhiteSpace(nombreMedicamento);
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}

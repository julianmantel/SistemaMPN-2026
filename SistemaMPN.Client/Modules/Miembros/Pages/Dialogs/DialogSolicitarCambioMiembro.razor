@using SistemaMPN.Shared.DTO
<MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.SwapHoriz" Color="Color.Warning" />
            <MudText Typo="Typo.h6">Solicitar Cambio de Miembro</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudText Typo="Typo.body1">
                Selecciona el miembro que va a estar involucrado en el cambio:
            </MudText>
            
            <MudSelect @bind-Value="idMiembroSeleccionado"
                       Label="Miembro"
                       Variant="Variant.Outlined"
                       Required="true"
                       T="int?"
                       Clearable="true">
                @foreach (var miembro in MiembrosGrupo.Where(m => m.id_miembro != IdLider))
                {
                    <MudSelectItem Value="@((int?)miembro.id_miembro)">
                        @miembro.nombre_completo (@miembro.dni)
                    </MudSelectItem>
                }
            </MudSelect>

            <MudAlert Severity="Severity.Warning">
                <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                    <MudText Typo="Typo.body2">
                        <strong>Importante:</strong> El gestor de miembros se encargará de aceptar su solicitud.
                    </MudText>
                </MudStack>
            </MudAlert>
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => MudDialog.Cancel()" 
                   Color="Color.Default" 
                   Variant="Variant.Outlined">
            Cancelar
        </MudButton>
        <MudButton OnClick="() => PedirCambio()" 
                   Color="Color.Primary" 
                   Variant="Variant.Filled" 
                   Disabled="@(pidiendoCambio || !idMiembroSeleccionado.HasValue)"
                   StartIcon="@Icons.Material.Filled.Send">
            @if (pidiendoCambio)
            {
                <MudText>Solicitando el cambio...</MudText>
            }
            else
            {
                <MudText>Solicitar Cambio</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>
@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public List<InfoMiembroGrupoDTO> MiembrosGrupo { get; set; }
    [Parameter] public int IdGrupoActual { get; set; }
    [Parameter] public int IdLider { get; set; }

    private int? idMiembroSeleccionado;
    private bool pidiendoCambio = false;

    private async Task PedirCambio()
    {
        try
        {
            if (idMiembroSeleccionado.HasValue)
            {
                var peticionCambioDTO = new PeticionCambioDTO
                {
                    IdGrupos = IdGrupoActual,
                    IdMiembros = idMiembroSeleccionado.Value,
                    Peticion = new PeticionDTO
                    {
                        Tipo = "Cambio",
                        IdLider = IdLider,
                        FechaSolicitud = DateTime.UtcNow,
                        Mensaje = "Cambio de miembro",
                    }
                };

                MudDialog.Close(DialogResult.Ok(peticionCambioDTO));
            }
        }
        catch(Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            MudDialog.Cancel();
        }
        finally
        {
            pidiendoCambio = false;
        }
    }

}

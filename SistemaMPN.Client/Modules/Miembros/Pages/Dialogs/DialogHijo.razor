@using SistemaMPN.Shared.DTO

<EditForm Model="hijo" OnValidSubmit="Guardar">
	<DataAnnotationsValidator />

    <MudDialog>
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.ChildCare" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Agregar Hijo</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="3">
                <MudTextField required="true" 
                              Label="Nombre" 
                              Variant="Variant.Outlined"
                              @bind-Value="hijo.nombre" 
                              For="@(() => hijo.nombre)"
                              Placeholder="Ingrese el nombre..."
                              Immediate="true" />
                <MudTextField required="true" 
                              Label="Apellido" 
                              Variant="Variant.Outlined"
                              @bind-Value="hijo.apellido" 
                              For="@(() => hijo.apellido)"
                              Placeholder="Ingrese el apellido..."
                              Immediate="true" />
            </MudStack>
        </DialogContent>

        <DialogActions>
            <MudButton OnClick="Cancelar" 
                       Color="Color.Default" 
                       Variant="Variant.Text">
                Cancelar
            </MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       ButtonType="ButtonType.Submit"
                       Disabled="@(!EsValido())"
                       StartIcon="@Icons.Material.Filled.Check">
                Guardar
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

	HijoDTO hijo = new HijoDTO();

    private void Guardar()
    {

        MudDialog.Close(DialogResult.Ok(hijo));
    }

    private bool EsValido()
    {
        return !string.IsNullOrWhiteSpace(hijo.nombre) 
        && !string.IsNullOrWhiteSpace(hijo.apellido);
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}

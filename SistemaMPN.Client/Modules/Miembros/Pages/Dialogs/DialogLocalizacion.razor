@using SistemaMPN.Shared.DTO

@inject HttpClient Http
@inject ISnackbar Snackbar

<EditForm Model="Localizacion" OnValidSubmit="Guardar">
    <MudDialog MaxWidth="MaxWidth.Medium" FullWidth="true">
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.LocationOn" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Agregar/Editar Localización</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <DataAnnotationsValidator />
            
            <MudGrid Spacing="3">
                <MudItem xs="12">
                    <MudAutocomplete T="string"
                                     Label="Seleccione un grupo"
                                     Value="@nombreSeleccionado"
                                     ValueChanged="(string nombreGrupo) => CargarGrupoSeleccionado(nombreGrupo)"
                                     Variant="Variant.Outlined"
                                     SearchFunc="Search1"
                                     Required="true"
                                     ToStringFunc="@(x => x)"
                                     Clearable="true"
                                     RequiredError="Se requiere un grupo para la localización" />
                </MudItem>

                <MudItem xs="12">
                    <MudSelect @bind-Value="Localizacion.Tipo"
                        Variant="Variant.Outlined"
                        Label="Tipo de localización"
                        For="@(() => Localizacion.Tipo)"
                        Clearable="true">

                        <MudSelectItem Value="@("Casa De Oracion")">Casa de Oración</MudSelectItem>
                        <MudSelectItem Value="@("Celula")">Célula</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12">
                    <MudTextField @bind-Value="Localizacion.Direccion"
                                  Label="Dirección"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  Immediate="true"
                                  For="@(() => Localizacion.Direccion)"
                                  Clearable="true"
                                  Placeholder="Ingrese la dirección completa...">
                    </MudTextField>
                </MudItem>
            </MudGrid>
        </DialogContent>

        <DialogActions>
            <MudButton ButtonType="ButtonType.Button"
                       OnClick="Cancelar"
                       Color="Color.Default"
                       Variant="Variant.Outlined">
                Cancelar
            </MudButton>

            <MudButton ButtonType="ButtonType.Submit"
                       Color="Color.Primary"
                       Variant="Variant.Filled"
                       StartIcon="@Icons.Material.Filled.Save">
                Guardar
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter]
    public LocalizacionDTO Localizacion { get; set; }

    private List<GrupoDTO>? grupos = null;
    private GrupoDTO grupo = new GrupoDTO();
    private string? nombreSeleccionado;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            nombreSeleccionado = Localizacion.Grupo.nombre ?? string.Empty;

            if (grupos == null)
            {
                try
                {
                    var resultGrupos = await Http.GetFromJsonAsync<List<GrupoDTO>>("api/localizacion/GetInfoGrupos");
                    if (resultGrupos.Any())
                    {
                        grupos = new List<GrupoDTO>();
                        foreach (var grupo in resultGrupos)
                        {
                            grupos.Add(grupo);
                        }
                        StateHasChanged();
                    }
                    else
                    {
                        Snackbar.Add("No se encontraron grupos", Severity.Warning);
                    }
                }
                catch (HttpRequestException httpEx)
                {
                    Snackbar.Add($"Error de conexión al cargar grupos: {httpEx.Message}", Severity.Error);
                }
                catch (Exception ex)
                {
                    Snackbar.Add($"Error al cargar los grupos: {ex.Message}", Severity.Error);
                }
            }
        }
    }

    private async void Guardar()
    {
        try
        {
            MudDialog.Close(DialogResult.Ok(Localizacion));
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar grupo: {ex.Message}");
        }
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }

    private async Task<IEnumerable<string>> Search1(String value, CancellationToken token)
    {
        await Task.Delay(5, token);

        if (string.IsNullOrEmpty(value))
            return grupos?.Select(x => x.nombre).ToList() ?? new List<string>();

        return grupos?.Where(x => x.nombre.Contains(value, StringComparison.InvariantCultureIgnoreCase))
                      .Select(x => x.nombre)
                      .AsEnumerable()
           ?? new List<string>();
    }

    private async Task CargarGrupoSeleccionado(string? nombreGrupo)
    {
        nombreSeleccionado = nombreGrupo;
        if (grupos == null) return;

        var seleccionado = grupos.FirstOrDefault(g => g.nombre.Equals(nombreGrupo));
        if (seleccionado != null)
        {
            Localizacion.Grupo.id_grupo = seleccionado.id_grupo;
            Localizacion.Grupo.nombre = seleccionado.nombre ?? string.Empty;
        }

        StateHasChanged();
    }
}
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			if (!seminariosCargados)
			{
				try
				{
					var resultSeminarios = await Http.GetFromJsonAsync<List<SeminarioDTO>>("api/seminarios/GetSeminarios");
					if (resultSeminarios?.Any() == true)
					{
						seminarios = resultSeminarios
						.Where(seminario => seminario.activo == true)
						.ToDictionary(seminario => seminario, _ => false);

						seminariosCargados = true;
						StateHasChanged();
					}
				}
				catch (Exception ex)
				{
					Console.WriteLine($"Error cargando seminarios: {ex.Message}");
				}
			}
		}
	}

	// ====== Foto del miembro ======
	IBrowserFile? fotoSeleccionada;
	string? FotoPreviewUrl;

	async Task OnFotoSelected(IBrowserFile? file)
	{
		if (file == null)
		{
			LimpiarFoto();
			return;
		}

		if (file.ContentType != "image/jpeg")
		{
			Snackbar.Add("La foto debe ser JPG.", Severity.Error);
			LimpiarFoto();
			return;
		}

		fotoSeleccionada = file;

		// preview
		var buffer = new byte[file.Size];
		await file.OpenReadStream(5 * 1024 * 1024).ReadAsync(buffer);
		FotoPreviewUrl = $"data:image/jpeg;base64,{Convert.ToBase64String(buffer)}";

		Snackbar.Add("Foto seleccionada. Se guardará al registrar.", Severity.Info);
	}

	void LimpiarFoto()
	{
		fotoSeleccionada = null;
		FotoPreviewUrl = null;
		StateHasChanged();
	}


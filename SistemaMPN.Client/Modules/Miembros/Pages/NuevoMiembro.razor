	async Task OnValidSubmit()
	{
		await Registrar();
	}

	void OnInvalidSubmit()
	{
		NavegerATabConError();

		var mensajes = editContext.GetValidationMessages().Take(5).ToList();
		if (mensajes.Any())
		{
			StringBuilder sb = new StringBuilder();
			mensajes.ForEach(m => sb.Append(m + "<br />"));
			if (editContext.GetValidationMessages().Count() > 5)
				sb.Append($"...y {editContext.GetValidationMessages().Count() - 5} error(es) más");

			Snackbar.Add((MarkupString)sb.ToString(), Severity.Error, config =>
			{
				config.RequireInteraction = true;
				config.DuplicatesBehavior = SnackbarDuplicatesBehavior.Prevent;
			});
		}
	}

	void NavegerATabConError()
	{
		foreach (var (tabIndex, tieneError) in TabValidaciones)
		{
			if (tieneError(miembro))
			{
				mudTabs.ActivatePanel(tabIndex);
				return;
			}
		}
		mudTabs.ActivatePanel(0);
	}

	async Task Registrar()
	{
		try
		{
			isLoading = true;
			StateHasChanged();
			Trim();

			if (miembro.info_eclesiastica.realizo_bautismo == false)
			{
				miembro.info_eclesiastica.fecha_de_bautismo = null;;
			}

			if (seminarios != null && seminarios.Count > 0)
			{
				var listaSeminarios = seminarios
					.Where(s => s.Value)
					.Select(s => s.Key)
					.ToList();
				foreach (var seminario in listaSeminarios)
				{
					miembro.info_eclesiastica.seminarios.Add(seminario);
				}
			}
			var form = new MultipartFormDataContent();

			// JSON del miembro
			var json = JsonSerializer.Serialize(miembro);
			form.Add(new StringContent(json, Encoding.UTF8, "application/json"), "miembroJson");

			// Foto (si seleccionó)
			if (fotoSeleccionada != null)
			{
				var stream = fotoSeleccionada.OpenReadStream(5 * 1024 * 1024);
				var fileContent = new StreamContent(stream);
				fileContent.Headers.ContentType =
					new System.Net.Http.Headers.MediaTypeHeaderValue("image/jpeg");

				form.Add(fileContent, "foto", fotoSeleccionada.Name);
			}

			var resp = await Http.PostAsync("api/miembros/RegistrarMiembro", form);

			if (!resp.IsSuccessStatusCode)
			{
				Snackbar.Add($"{resp.Content.ReadAsStringAsync().Result}", Severity.Error);
				return;
			} else
			{
				Snackbar.Add($"Se ha registrado al miembro: { miembro.info_basica_miembro.nombre }", Severity.Success);
			}

		}
		finally
		{
			isLoading = false;
			StateHasChanged();
		}
	}


@using SistemaMPN.Shared.DTO

@inject ISnackbar Snackbar

<EditForm Model="grupo" OnValidSubmit="Guardar">
    <DataAnnotationsValidator />

    <MudDialog>
        <TitleContent>
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.Groups" Color="Color.Primary" />
                <MudText Typo="Typo.h6">Crear Nuevo Grupo</MudText>
            </MudStack>
        </TitleContent>
        <DialogContent>
            <MudStack Spacing="4">
                <MudTextField Label="Nombre del Grupo" 
                              @bind-Value="grupo.nombre" 
                              For="@(() => grupo.nombre)"
                              Variant="Variant.Outlined"
                              Required="true"
                              Immediate="true"
                              Placeholder="Ingrese el nombre del grupo..." />

                <MudSelect T="int?"
                           Label="Seleccionar Líder"
                           @bind-Value="grupo.id_lider"
                           Required="true"
                           Variant="Variant.Outlined"
                           For="@(() => grupo.id_lider)"
                           Disabled="@(cargandoMiembros || miembrosDisponibles == null || !miembrosDisponibles.Any())">
                    <MudSelectItem Value="@((int?)null)">
                        @if (cargandoMiembros)
                        {
                            <text>-- Cargando líderes disponibles... --</text>
                        }
                        else if (miembrosDisponibles == null || !miembrosDisponibles.Any())
                        {
                            <text>-- No hay líderes disponibles --</text>
                        }
                        else
                        {
                            <text>-- Seleccione un líder --</text>
                        }
                    </MudSelectItem>

                    @if (miembrosDisponibles != null && miembrosDisponibles.Any())
                    {
                        @foreach (var miembro in miembrosDisponibles)
                        {
                            <MudSelectItem Value="@((int?)miembro.id_miembro)">
                                @($"{miembro.nombre_completo} - DNI: {miembro.dni}")
                            </MudSelectItem>
                        }
                    }
                </MudSelect>

                @if (cargandoMiembros)
                {
                    <MudStack Spacing="1">
                        <MudProgressLinear Color="Color.Primary" Indeterminate="true" />
                        <MudText Typo="Typo.caption" Color="Color.Secondary">Cargando líderes disponibles...</MudText>
                    </MudStack>
                }
                else if (miembrosDisponibles != null && !miembrosDisponibles.Any())
                {
                    <MudAlert Severity="Severity.Warning">
                        <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
                            <MudText Typo="Typo.body2">
                                No hay miembros con permisos de liderazgo disponibles para crear un grupo.
                            </MudText>
                        </MudStack>
                    </MudAlert>
                }
            </MudStack>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="() => MudDialog.Cancel()" 
                       Color="Color.Default" 
                       Variant="Variant.Outlined"
                       Disabled="@(guardando || cargandoMiembros)">
                Cancelar
            </MudButton>
            <MudButton Color="Color.Primary"
                       Variant="Variant.Filled"
                       Disabled="@(string.IsNullOrWhiteSpace(grupo.nombre) || !grupo.id_lider.HasValue || guardando || cargandoMiembros || miembrosDisponibles == null || !miembrosDisponibles.Any())"
                       StartIcon="@(guardando ? null : Icons.Material.Filled.Save)"
                       ButtonType="ButtonType.Submit">
                @if (guardando)
                {
                    <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" />
                    <MudText>Guardando</MudText>
                }
                else
                {
                    <MudText>Guardar</MudText>
                }
            </MudButton>
        </DialogActions>
    </MudDialog>
</EditForm>


@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Inject] private HttpClient Http { get; set; }

    private GrupoDTO grupo = new();

    private List<InfoMiembroGrupoDTO>? miembrosDisponibles = null;
    private bool cargandoMiembros = false;
    private bool guardando = false;

    protected override async Task OnInitializedAsync()
    {
        await GetMiembrosParaLiderazgo();
    }

    private async Task GetMiembrosParaLiderazgo()
    {
        cargandoMiembros = true;
        StateHasChanged();
        try
        {
            var response = await Http.GetFromJsonAsync<List<InfoMiembroGrupoDTO>>("api/grupo/GetMiembrosParaLiderazgo");
            miembrosDisponibles = response ?? new List<InfoMiembroGrupoDTO>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar miembros: {ex.Message}");
            miembrosDisponibles = new List<InfoMiembroGrupoDTO>();
        }
        finally
        {
            cargandoMiembros = false;
            StateHasChanged();
        }
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(grupo.nombre) || !grupo.id_lider.HasValue)
        {
            return;
        }

        guardando = true;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/grupo/CrearGrupo", grupo);

            if (response.IsSuccessStatusCode)
            {
                var grupoCreado = await response.Content.ReadFromJsonAsync<GrupoDTO>();
                Snackbar.Add("Grupo creado exitosamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(grupoCreado));
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Console.WriteLine($"Error al crear grupo: {error}");
                Snackbar.Add($"Error al crear el grupo: {error}", Severity.Error);
                await ShowErrorMessage(error);
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add($"Error inesperado: {ex.Message}", Severity.Error);
            await ShowErrorMessage("Ocurrió un error inesperado al crear el grupo.");
        }
        finally
        {
            guardando = false;
            StateHasChanged();
        }
    }

    private async Task ShowErrorMessage(string error)
    {
        MudDialog.Cancel();
    }
}
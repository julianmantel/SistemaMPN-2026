@using System.Text.RegularExpressions
@inject ISnackbar Snackbar

<MudDialog>
    <TitleContent>
        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
            <MudIcon Icon="@Icons.Material.Filled.Badge" Color="Color.Primary" />
            <MudText Typo="Typo.h6">@(string.IsNullOrEmpty(OcupacionActual) ? "Agregar" : "Editar") Ocupación</MudText>
        </MudStack>
    </TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="nombreOcupacion"
                      Label="Ocupación"
                      Variant="Variant.Outlined"
                      Required="true"
                      Immediate="true"
                      Placeholder="Ingrese la ocupación del miembro..." />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancelar" 
                   Color="Color.Default" 
                   Variant="Variant.Outlined">
            Cancelar
        </MudButton>
        <MudButton OnClick="Guardar" 
                   Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@guardando"
                   StartIcon="@(guardando ? null : Icons.Material.Filled.Save)">
            @if (guardando)
            {
                <MudProgressCircular Class="me-2" Size="Size.Small" Indeterminate="true" />
                <MudText>Guardando</MudText>
            }
            else
            {
                <MudText>Guardar</MudText>
            }
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; }

    [Parameter] public int IdMiembro { get; set; }
    [Parameter] public string OcupacionActual { get; set; }

    [Inject] private HttpClient Http { get; set; }

    private string nombreOcupacion;
    private bool guardando = false;

    protected override void OnInitialized()
    {
        nombreOcupacion = OcupacionActual ?? string.Empty;
    }

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(nombreOcupacion))
        {
            MudDialog.Cancel();
            return;
        }

        if (!Regex.IsMatch(nombreOcupacion, @"^(?=.*[A-Za-z])(?=.*\d|.*[A-Za-z]).*\S.*$"))
        {
            Snackbar.Add("La ocupacion debe contener al menos una letra y no puede estar vacío o solo con espacios.", Severity.Error);
            return;
        }

        if (nombreOcupacion.Length > 50)
        {
            Snackbar.Add("La ocupacion no puede superar los 50 caracteres.", Severity.Error);
            return;
        }

        guardando = true;
        StateHasChanged();

        try
        {

            // Llamar a la API
            var response = await Http.PutAsJsonAsync($"api/grupo/CambiarOcupacionMiembro/{IdMiembro}", nombreOcupacion);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add("Ocupación actualizada correctamente", Severity.Success);
                MudDialog.Close(DialogResult.Ok(nombreOcupacion));
            }
            else
            {
                // Manejar error
                Console.WriteLine($"Error al actualizar ocupación: {response.StatusCode}");
                Snackbar.Add("Error al actualizar ocupación", Severity.Error);
                MudDialog.Cancel();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            MudDialog.Cancel();
        }
        finally
        {
            guardando = false;
        }
    }

    private void Cancelar()
    {
        MudDialog.Cancel();
    }
}